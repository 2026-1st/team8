        "# ============================================================\n",
        "# 8. Monthly Trend Keyword Feature\n",
        "# ============================================================\n",
        "\n",
        "def make_trend_features(base_df, book_keywords, monthly_keywords):\n",
        "    if monthly_keywords.empty:\n",
        "        base_df[\"trend_keyword_overlap_count\"] = np.nan\n",
        "        base_df[\"trend_keyword_overlap_ratio\"] = np.nan\n",
        "        base_df[\"trend_weight_sum\"] = np.nan\n",
        "        return base_df\n",
        "\n",
        "    mk = monthly_keywords.copy()\n",
        "    bk = book_keywords.copy()\n",
        "\n",
        "    # 월 컬럼 처리\n",
        "    mk[\"month\"] = pd.to_datetime(mk[\"month\"], errors=\"coerce\")\n",
        "    mk[\"word\"] = mk[\"word\"].fillna(\"\").astype(str)\n",
        "    mk[\"weight\"] = pd.to_numeric(mk[\"weight\"], errors=\"coerce\")\n",
        "\n",
        "    bk[\"word\"] = bk[\"word\"].fillna(\"\").astype(str)\n",
        "    bk[\"weight\"] = pd.to_numeric(bk[\"weight\"], errors=\"coerce\")\n",
        "\n",
        "    # 도서 키워드와 월별 키워드를 word 기준으로 연결\n",
        "    overlap = bk.merge(\n",
        "        mk[[\"month\", \"word\", \"weight\"]],\n",
        "        on=\"word\",\n",
        "        how=\"inner\",\n",
        "        suffixes=(\"_book\", \"_trend\")\n",
        "    )\n",
        "\n",
        "    if overlap.empty:\n",
        "        base_df[\"trend_keyword_overlap_count\"] = 0\n",
        "        base_df[\"trend_keyword_overlap_ratio\"] = 0\n",
        "        base_df[\"trend_weight_sum\"] = 0\n",
        "        return base_df\n",
        "\n",
        "    trend_agg = overlap.groupby([\"isbn13\", \"month\"]).agg(\n",
        "        trend_keyword_overlap_count=(\"word\", \"nunique\"),\n",
        "        trend_weight_sum=(\"weight_trend\", \"sum\"),\n",
        "        trend_weight_mean=(\"weight_trend\", \"mean\")\n",
        "    ).reset_index()\n",
        "\n",
        "    # 도서별 전체 키워드 수\n",
        "    keyword_count = bk.groupby(\"isbn13\").agg(\n",
        "        total_book_keyword_count=(\"word\", \"nunique\")\n",
        "    ).reset_index()\n",
        "\n",
        "    trend_agg = trend_agg.merge(keyword_count, on=\"isbn13\", how=\"left\")\n",
        "\n",
        "    trend_agg[\"trend_keyword_overlap_ratio\"] = (\n",
        "        trend_agg[\"trend_keyword_overlap_count\"] /\n",
        "        trend_agg[\"total_book_keyword_count\"].replace(0, np.nan)\n",
        "    )\n",
        "\n",
        "    # base_df의 base_month와 trend_agg의 month 연결\n",
        "    result = base_df.merge(\n",
        "        trend_agg[\n",
        "            [\n",
        "                \"isbn13\",\n",
        "                \"month\",\n",
        "                \"trend_keyword_overlap_count\",\n",
        "                \"trend_keyword_overlap_ratio\",\n",
        "                \"trend_weight_sum\"\n",
        "            ]\n",
        "        ],\n",
        "        left_on=[\"isbn13\", \"base_month\"],\n",
        "        right_on=[\"isbn13\", \"month\"],\n",
        "        how=\"left\"\n",
        "    )\n",
        "\n",
        "    result = result.drop(columns=[\"month\"], errors=\"ignore\")\n",
        "\n",
        "    result[\"trend_keyword_overlap_count\"] = result[\"trend_keyword_overlap_count\"].fillna(0)\n",
        "    result[\"trend_keyword_overlap_ratio\"] = result[\"trend_keyword_overlap_ratio\"].fillna(0)\n",
        "    result[\"trend_weight_sum\"] = result[\"trend_weight_sum\"].fillna(0)\n",
        "\n",
        "    return result"
      ],
      "metadata": {
        "id": "bxa6_EkzUu7I"
      },
      "execution_count": 14,
      "outputs": []

    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 3. Target 생성\n",
        "# y = 다음 달 대출건수\n",
        "# ============================================================\n",
        "\n",
        "loan[\"target_next_month_loanCnt\"] = (\n",
        "    loan.groupby(\"isbn13\")[\"monthly_loanCnt\"].shift(-1)\n",
        ")\n",
        "\n",
        "# 기준월 feature 생성\n",
        "loan[\"base_month\"] = loan[\"month\"]\n",
        "loan[\"base_year\"] = loan[\"base_month\"].dt.year\n",
        "loan[\"base_month_num\"] = loan[\"base_month\"].dt.month\n",
        "\n",
        "print(loan[[\"isbn13\", \"base_month\", \"monthly_loanCnt\", \"target_next_month_loanCnt\"]].head(10))"
      ],

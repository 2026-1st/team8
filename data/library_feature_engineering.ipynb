    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 10. Hot Trend Feature\n",
        "# ============================================================\n",
        "\n",
        "def make_hot_trend_features(hot_trends):\n",
        "    if hot_trends.empty:\n",
        "        return pd.DataFrame(columns=[\n",
        "            \"isbn13\",\n",
        "            \"hot_month\",\n",
        "            \"is_hot_trend\",\n",
        "            \"hot_difference_max\",\n",
        "            \"rank_jump_score\"\n",
        "        ])\n",
        "\n",
        "    ht = hot_trends.copy()\n",
        "\n",
        "    # 날짜 처리\n",
        "    if \"result_date\" in ht.columns:\n",
        "        ht[\"hot_month\"] = pd.to_datetime(ht[\"result_date\"], errors=\"coerce\").dt.to_period(\"M\").dt.to_timestamp()\n",
        "    elif \"search_date\" in ht.columns:\n",
        "        ht[\"hot_month\"] = pd.to_datetime(ht[\"search_date\"], errors=\"coerce\").dt.to_period(\"M\").dt.to_timestamp()\n",
        "    else:\n",
        "        raise ValueError(\"hot_trends에 result_date 또는 search_date 컬럼이 필요합니다.\")\n",
        "\n",
        "    ht[\"difference\"] = pd.to_numeric(ht.get(\"difference\"), errors=\"coerce\")\n",
        "    ht[\"baseWeekRank\"] = pd.to_numeric(ht.get(\"baseWeekRank\"), errors=\"coerce\")\n",
        "    ht[\"pastWeekRank\"] = pd.to_numeric(ht.get(\"pastWeekRank\"), errors=\"coerce\")\n",
        "\n",
        "    # 순위 상승폭: 과거 순위 - 현재 순위\n",
        "    ht[\"rank_jump_score_raw\"] = ht[\"pastWeekRank\"] - ht[\"baseWeekRank\"]\n",
        "\n",
        "    hot_features = ht.groupby([\"isbn13\", \"hot_month\"]).agg(\n",
        "        is_hot_trend=(\"isbn13\", \"size\"),\n",
        "        hot_difference_max=(\"difference\", \"max\"),\n",
        "        rank_jump_score=(\"rank_jump_score_raw\", \"max\")\n",
        "    ).reset_index()\n",
        "\n",
        "    hot_features[\"is_hot_trend\"] = (hot_features[\"is_hot_trend\"] > 0).astype(int)\n",
        "\n",
        "    return hot_features\n",
        "\n",
        "\n",
        "hot_features = make_hot_trend_features(hot_trends)\n",
        "\n",
        "print(hot_features.head())"
      ],

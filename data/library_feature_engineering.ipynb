    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 4. Loan History 기반 Feature\n",
        "# ============================================================\n",
        "\n",
        "loan = loan.sort_values([\"isbn13\", \"month\"]).reset_index(drop=True)\n",
        "\n",
        "# lag features\n",
        "for lag in [1, 2, 3]:\n",
        "    loan[f\"loan_lag_{lag}\"] = (\n",
        "        loan.groupby(\"isbn13\")[\"monthly_loanCnt\"].shift(lag)\n",
        "    )\n",
        "\n",
        "# rolling features\n",
        "g_loan = loan.groupby(\"isbn13\")[\"monthly_loanCnt\"]\n",
        "\n",
        "loan[\"loan_ma_3\"] = (\n",
        "    g_loan.shift(1)\n",
        "    .groupby(loan[\"isbn13\"])\n",
        "    .rolling(3)\n",
        "    .mean()\n",
        "    .reset_index(level=0, drop=True)\n",
        ")\n",
        "\n",
        "loan[\"loan_ma_6\"] = (\n",
        "    g_loan.shift(1)\n",
        "    .groupby(loan[\"isbn13\"])\n",
        "    .rolling(6)\n",
        "    .mean()\n",
        "    .reset_index(level=0, drop=True)\n",
        ")\n",
        "\n",
        "loan[\"loan_sum_3\"] = (\n",
        "    g_loan.shift(1)\n",
        "    .groupby(loan[\"isbn13\"])\n",
        "    .rolling(3)\n",
        "    .sum()\n",
        "    .reset_index(level=0, drop=True)\n",
        ")\n",
        "\n",
        "loan[\"loan_sum_6\"] = (\n",
        "    g_loan.shift(1)\n",
        "    .groupby(loan[\"isbn13\"])\n",
        "    .rolling(6)\n",
        "    .sum()\n",
        "    .reset_index(level=0, drop=True)\n",
        ")\n",
        "\n",
        "loan[\"loan_std_6\"] = (\n",
        "    g_loan.shift(1)\n",
        "    .groupby(loan[\"isbn13\"])\n",
        "    .rolling(6)\n",
        "    .std()\n",
        "    .reset_index(level=0, drop=True)\n",
        ")\n",
        "\n",
        "# 직전월 대비 증가율\n",
        "loan[\"loan_growth_1m\"] = (\n",
        "    (loan[\"loan_lag_1\"] - loan[\"loan_lag_2\"]) /\n",
        "    (loan[\"loan_lag_2\"].replace(0, np.nan))\n",
        ")\n",
        "\n",
        "loan[\"loan_growth_1m\"] = loan[\"loan_growth_1m\"].replace([np.inf, -np.inf], np.nan)\n",
        "\n",
        "# 최근 6개월 trend slope\n",
        "def calc_slope(values):\n",
        "    values = np.array(values, dtype=float)\n",
        "    if np.isnan(values).any():\n",
        "        return np.nan\n",
        "    x = np.arange(len(values))\n",
        "    slope = np.polyfit(x, values, 1)[0]\n",
        "    return slope\n",
        "\n",
        "loan[\"loan_trend_slope_6\"] = (\n",
        "    g_loan.shift(1)\n",
        "    .groupby(loan[\"isbn13\"])\n",
        "    .rolling(6)\n",
        "    .apply(calc_slope, raw=False)\n",
        "    .reset_index(level=0, drop=True)\n",
        ")\n",
        "\n",
        "# ranking features\n",
        "loan[\"rank_lag_1\"] = loan.groupby(\"isbn13\")[\"monthly_ranking\"].shift(1)\n",
        "loan[\"rank_lag_2\"] = loan.groupby(\"isbn13\")[\"monthly_ranking\"].shift(2)\n",
        "\n",
        "# ranking은 숫자가 작을수록 좋은 순위\n",
        "# rank_lag_2 - rank_lag_1 > 0 이면 순위 상승\n",
        "loan[\"rank_change_1m\"] = loan[\"rank_lag_2\"] - loan[\"rank_lag_1\"]\n",
        "\n",
        "g_rank = loan.groupby(\"isbn13\")[\"monthly_ranking\"]\n",
        "\n",
        "loan[\"rank_ma_3\"] = (\n",
        "    g_rank.shift(1)\n",
        "    .groupby(loan[\"isbn13\"])\n",
        "    .rolling(3)\n",
        "    .mean()\n",
        "    .reset_index(level=0, drop=True)\n",
        ")\n",
        "\n",
        "loan_features = loan.copy()\n",
        "\n",
        "print(loan_features.head())"
      ],
      "metadata": {

    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 2. Basic Preprocessing\n",
        "# ============================================================\n",
        "\n",
        "def clean_isbn(series):\n",
        "    return (\n",
        "        series.astype(str)\n",
        "        .str.replace(\".0\", \"\", regex=False)\n",
        "        .str.strip()\n",
        "    )\n",
        "\n",
        "for df_obj in [loan, books, groups, keywords, co_books, monthly_keywords, hot_trends]:\n",
        "    # Check if df_obj is a DataFrame and has 'isbn13' column before processing\n",
        "    if isinstance(df_obj, pd.DataFrame) and \"isbn13\" in df_obj.columns:\n",
        "        df_obj[\"isbn13\"] = clean_isbn(df_obj[\"isbn13\"])\n",
        "\n",
        "print(f\"[Initial State] loan DataFrame shape: {loan.shape}\")\n",
        "print(f\"Nulls in 'isbn13' before date/numeric conversion: {loan['isbn13'].isnull().sum()}\")\n",
        "print(f\"Nulls in 'month' before date/numeric conversion: {loan['month'].isnull().sum()}\")\n",
        "\n",
        "# loan_history 날짜 처리\n",
        "# Adjusting format to match 'YYYY년 MM월'\n",
        "loan[\"month\"] = pd.to_datetime(loan[\"month\"], format='%Y년 %m월', errors=\"coerce\")\n",
        "loan[\"monthly_loanCnt\"] = pd.to_numeric(loan[\"monthly_loanCnt\"], errors=\"coerce\")\n",
        "loan[\"monthly_ranking\"] = pd.to_numeric(loan[\"monthly_ranking\"], errors=\"coerce\")\n",
        "\n",
        "print(f\"[After Type Conversion] loan DataFrame shape: {loan.shape}\")\n",
        "print(f\"NaT in 'month' after to_datetime: {loan['month'].isnull().sum()}\")\n",
        "print(f\"Nulls in 'monthly_loanCnt' after to_numeric: {loan['monthly_loanCnt'].isnull().sum()}\")\n",
        "print(f\"Nulls in 'monthly_ranking' after to_numeric: {loan['monthly_ranking'].isnull().sum()}\")\n",
        "\n",
        "# Fill NaN values for numeric columns that might be used in calculations, to prevent dropping rows\n",
        "loan[\"monthly_loanCnt\"] = loan[\"monthly_loanCnt\"].fillna(0)\n",
        "loan[\"monthly_ranking\"] = loan[\"monthly_ranking\"].fillna(0)\n",
        "\n",
        "print(f\"[After Fillna Numeric] Nulls in 'monthly_loanCnt': {loan['monthly_loanCnt'].isnull().sum()}\")\n",
        "print(f\"[After Fillna Numeric] Nulls in 'monthly_ranking': {loan['monthly_ranking'].isnull().sum()}\")\n",
        "\n",
        "# Only drop rows where 'isbn13' or 'month' are unrecoverably missing/invalid\n",
        "# If 'month' is entirely NaT, it means the format assumption was wrong or data is truly bad.\n",
        "loan = loan.dropna(subset=[\"isbn13\", \"month\"])\n",
        "loan = loan.sort_values([\"isbn13\", \"month\"]).reset_index(drop=True)\n",
        "\n",
        "print(f\"[After Dropna] loan DataFrame shape: {loan.shape}\")\n",
        "print(loan.head())"
      ],

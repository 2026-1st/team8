            "3  9788901276533 2025-08-01             1309                     1205.0\n",
            "4  9788901276533 2025-09-01             1205                     1179.0\n",
            "5  9788901276533 2025-10-01             1179                     1312.0\n",
            "6  9788901276533 2025-11-01             1312                     1312.0\n",
            "7  9788901276533 2025-12-01             1312                     1406.0\n",
            "8  9788901276533 2026-01-01             1406                     1040.0\n",
            "9  9788901276533 2026-02-01             1040                     1040.0\n"
          ]
        }

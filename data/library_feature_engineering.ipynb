    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 5. Book Metadata Feature\n",
        "# ============================================================\n",
        "\n",
        "books[\"publication_year\"] = pd.to_numeric(\n",
        "    books[\"publication_year\"], errors=\"coerce\"\n",
        ")\n",
        "\n",
        "books[\"bookname\"] = books[\"bookname\"].fillna(\"\")\n",
        "books[\"authors\"] = books[\"authors\"].fillna(\"unknown\")\n",
        "books[\"publisher\"] = books[\"publisher\"].fillna(\"unknown\")\n",
        "books[\"class_no\"] = books[\"class_no\"].astype(str).replace(\"nan\", np.nan)\n",
        "\n",
        "books[\"title_length\"] = books[\"bookname\"].str.len()\n",
        "\n",
        "books[\"class_main\"] = books[\"class_no\"].astype(str).str[0]\n",
        "books[\"class_mid\"] = books[\"class_no\"].astype(str).str[:2]\n",
        "\n",
        "# 출판사 등장 빈도\n",
        "publisher_freq = books[\"publisher\"].value_counts().to_dict()\n",
        "books[\"publisher_freq\"] = books[\"publisher\"].map(publisher_freq)\n",
        "\n",
        "# 저자 등장 빈도\n",
        "author_freq = books[\"authors\"].value_counts().to_dict()\n",
        "books[\"author_freq\"] = books[\"authors\"].map(author_freq)\n",
        "\n",
        "book_features = books[\n",
        "    [\n",
        "        \"isbn13\",\n",
        "        \"publication_year\",\n",
        "        \"title_length\",\n",
        "        \"class_main\",\n",
        "        \"class_mid\",\n",
        "        \"publisher\",\n",
        "        \"authors\",\n",
        "        \"publisher_freq\",\n",
        "        \"author_freq\"\n",
        "    ]\n",
        "].drop_duplicates(\"isbn13\")\n",
        "\n",
        "print(book_features.head())"
      ],

      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 14. Missing Value 처리\n",
        "# ============================================================\n",
        "\n",
        "# target이 없는 마지막 달은 학습 불가\n",
        "model_df = model_df.dropna(subset=[target_col]).copy()\n",
        "\n",
        "# 숫자형 feature 결측 처리\n",
        "for col in feature_cols:\n",
        "    model_df[col] = pd.to_numeric(model_df[col], errors=\"coerce\")\n",
        "\n",
        "# 방법 1: 결측치를 0으로 채우기\n",
        "model_df[feature_cols] = model_df[feature_cols].fillna(0)\n",
        "\n",
        "# target도 숫자로 변환\n",
        "model_df[target_col] = pd.to_numeric(model_df[target_col], errors=\"coerce\")\n",
        "model_df = model_df.dropna(subset=[target_col])\n",
        "\n",
        "print(model_df.isna().sum().sort_values(ascending=False).head(20))\n",
        "print(model_df.shape)"
      ],

      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 1. Raw CSV Load\n",
        "# ============================================================\n",
        "\n",
        "loan = pd.read_csv(RAW_DIR / \"loan_history_raw.csv\")\n",
        "books = pd.read_csv(RAW_DIR / \"usage_books_raw.csv\")\n",
        "groups = pd.read_csv(RAW_DIR / \"loan_groups_raw.csv\")\n",
        "keywords = pd.read_csv(RAW_DIR / \"book_keywords_raw.csv\")\n",
        "co_books = pd.read_csv(RAW_DIR / \"co_loan_books_raw.csv\")\n",
        "\n",
        "# 월별 키워드, 급상승 도서는 연도별 파일명일 가능성이 높으므로 glob으로 읽기\n",
        "monthly_keyword_files = sorted(RAW_DIR.glob(\"monthly_keywords_*.csv\"))\n",
        "hot_trend_files = sorted(RAW_DIR.glob(\"hot_trends_*.csv\"))\n",
        "\n",
        "monthly_keywords = pd.concat(\n",
        "    [pd.read_csv(f) for f in monthly_keyword_files],\n",
        "    ignore_index=True\n",
        ") if monthly_keyword_files else pd.DataFrame()\n",
        "\n",
        "hot_trends = pd.concat(\n",
        "    [pd.read_csv(f) for f in hot_trend_files],\n",
        "    ignore_index=True\n",
        ") if hot_trend_files else pd.DataFrame()\n",
        "\n",
        "print(\"loan:\", loan.shape)\n",
        "print(\"books:\", books.shape)\n",
        "print(\"groups:\", groups.shape)\n",
        "print(\"keywords:\", keywords.shape)\n",
        "print(\"monthly_keywords:\", monthly_keywords.shape)\n",
        "print(\"co_books:\", co_books.shape)\n",
        "print(\"hot_trends:\", hot_trends.shape)"
      ],

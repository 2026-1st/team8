        "    co_loan_avg_publication_year=(\"related_publication_year\", \"mean\")\n",
        ").reset_index()\n",
        "\n",
        "# 원도서 publisher 붙이기\n",
        "co_tmp = co_books.merge(\n",
        "    books[[\"isbn13\", \"publisher\"]],\n",
        "    on=\"isbn13\",\n",
        "    how=\"left\"\n",
        ")\n",
        "\n",
        "co_tmp[\"same_publisher\"] = (\n",
        "    co_tmp[\"publisher\"].fillna(\"unknown\") ==\n",
        "    co_tmp[\"related_publisher\"].fillna(\"unknown\")\n",
        ").astype(int)\n",
        "\n",
        "same_pub = co_tmp.groupby(\"isbn13\").agg(\n",
        "    co_loan_same_publisher_count=(\"same_publisher\", \"sum\")\n",
        ").reset_index()\n",
        "\n",
        "co_features = co_agg.merge(same_pub, on=\"isbn13\", how=\"left\")\n",
        "\n",

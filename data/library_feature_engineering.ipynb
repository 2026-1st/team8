    {
      "cell_type": "markdown",
      "source": [
        "### Highly Correlated Feature Pairs\n",
        "\n",
        "히트맵에서 높은 상관관계를 보인 피처 쌍들을 자세히 살펴보겠습니다. 절대값이 `0.9` 이상인 상관계수를 가진 피처 쌍들을 추출합니다."
      ],
      "metadata": {
        "id": "KQ9CiZDsVufN"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "\n",
        "# 상관계수 행렬의 복사본을 만들어 자기 자신과의 상관관계(1) 및 중복 쌍 제거\n",
        "correlation_threshold = 0.9 # 높은 상관관계의 기준치\n",
        "\n",
        "# 상삼각 행렬만 추출하여 중복 방지\n",
        "uppertri_corr = correlation_matrix.where(np.triu(np.ones(correlation_matrix.shape), k=1).astype(bool))\n",
        "\n",
        "# 절대값 기준으로 높은 상관관계 피처 쌍 찾기\n",
        "highly_correlated_pairs = []\n",
        "for col in uppertri_corr.columns:\n",
        "    for row in uppertri_corr.index:\n",
        "        if uppertri_corr.loc[row, col] > correlation_threshold or uppertri_corr.loc[row, col] < -correlation_threshold:\n",
        "            highly_correlated_pairs.append((row, col, uppertri_corr.loc[row, col]))\n",
        "\n",
        "# 결과를 데이터프레임으로 변환하여 보기 쉽게 정렬\n",
        "highly_correlated_df = pd.DataFrame(highly_correlated_pairs, columns=['Feature 1', 'Feature 2', 'Correlation'])\n",
        "highly_correlated_df = highly_correlated_df.sort_values(by='Correlation', ascending=False).reset_index(drop=True)\n",
        "\n",
        "if not highly_correlated_df.empty:\n",
        "    print(f\"Absolute correlation > {correlation_threshold}인 피처 쌍:\\n\")\n",
        "    display(highly_correlated_df)\n",
        "else:\n",
        "    print(f\"Absolute correlation > {correlation_threshold}인 피처 쌍을 찾을 수 없습니다.\")"
      ],

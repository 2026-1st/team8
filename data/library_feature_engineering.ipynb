      "source": [
        "# loan_history_raw.csv 파일을 다시 로드하여 loan DataFrame을 업데이트합니다.\n",
        "loan = pd.read_csv(RAW_DIR / \"loan_history_raw.csv\")\n",
        "print(\"loan DataFrame을 다시 로드했습니다. 새로운 shape:\", loan.shape)\n",
        "print(loan.head())"
      ],

    {
      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# 6. User Group Feature\n",
        "# ============================================================\n",
        "\n",
        "groups[\"loanCnt\"] = pd.to_numeric(groups[\"loanCnt\"], errors=\"coerce\")\n",
        "groups[\"age\"] = groups[\"age\"].fillna(\"unknown\").astype(str)\n",
        "groups[\"gender\"] = groups[\"gender\"].fillna(\"unknown\").astype(str)\n",
        "\n",
        "# 기본 aggregate\n",
        "group_agg = groups.groupby(\"isbn13\").agg(\n",
        "    group_loanCnt_sum=(\"loanCnt\", \"sum\"),\n",
        "    group_loanCnt_max=(\"loanCnt\", \"max\"),\n",
        "    age_group_count=(\"age\", \"nunique\"),\n",
        "    gender_group_count=(\"gender\", \"nunique\")\n",
        ").reset_index()\n",
        "\n",
        "# dominant group: 가장 많이 대출한 age/gender 조합\n",
        "idx = groups.groupby(\"isbn13\")[\"loanCnt\"].idxmax()\n",
        "dominant = groups.loc[idx, [\"isbn13\", \"age\", \"gender\", \"loanCnt\"]].copy()\n",
        "\n",
        "dominant = dominant.rename(columns={\n",
        "    \"age\": \"main_age\",\n",
        "    \"gender\": \"main_gender\",\n",
        "    \"loanCnt\": \"dominant_group_loanCnt\"\n",
        "})\n",
        "\n",
        "group_features = group_agg.merge(dominant, on=\"isbn13\", how=\"left\")\n",
        "\n",
        "group_features[\"dominant_group_ratio\"] = (\n",
        "    group_features[\"dominant_group_loanCnt\"] /\n",
        "    group_features[\"group_loanCnt_sum\"].replace(0, np.nan)\n",
        ")\n",
        "\n",
        "# 성별 비율 feature\n",
        "gender_pivot = (\n",
        "    groups.pivot_table(\n",
        "        index=\"isbn13\",\n",
        "        columns=\"gender\",\n",
        "        values=\"loanCnt\",\n",
        "        aggfunc=\"sum\",\n",
        "        fill_value=0\n",
        "    )\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "# 컬럼명 정리\n",
        "gender_pivot.columns = [str(c) for c in gender_pivot.columns]\n",
        "\n",
        "# 가능한 성별 코드/값에 대응\n",
        "# 데이터에 따라 gender 값이 '0', '1', '2', '남성', '여성' 등일 수 있음\n",
        "gender_cols = [c for c in gender_pivot.columns if c != \"isbn13\"]\n",
        "gender_pivot[\"gender_total\"] = gender_pivot[gender_cols].sum(axis=1)\n",
        "\n",
        "for col in gender_cols:\n",
        "    gender_pivot[f\"gender_{col}_ratio\"] = (\n",
        "        gender_pivot[col] / gender_pivot[\"gender_total\"].replace(0, np.nan)\n",
        "    )\n",
        "\n",
        "ratio_cols = [\"isbn13\"] + [c for c in gender_pivot.columns if c.endswith(\"_ratio\")]\n",
        "\n",
        "group_features = group_features.merge(\n",
        "    gender_pivot[ratio_cols],\n",
        "    on=\"isbn13\",\n",
        "    how=\"left\"\n",
        ")\n",
        "\n",
        "print(group_features.head())"
      ],
